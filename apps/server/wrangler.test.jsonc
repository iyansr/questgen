{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "questgen-server-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "BETA_MODE": "false",
    "CORS_ORIGIN": "http://localhost:3001",
    "SERVER_URL": "http://localhost:3000",
    "CHROMA_TENANT": "test-tenant",
    "CHROMA_DATABASE": "test-db",
    "DATABASE_URL": "postgresql://postgres:postgres@127.0.0.1:5432/questgen_test",
    "JWT_SECRET": "test-jwt-secret-blackbox",
    "OPENROUTER_API_KEY": "test-openrouter-key",
    "MISTRAL_API_KEY": "test-mistral-key",
    "TAVILY_API_KEY": "test-tavily-key",
    "LANGFUSE_PUBLIC_KEY": "test-langfuse-public",
    "LANGFUSE_SECRET_KEY": "test-langfuse-secret"
  },
  "r2_buckets": [
    {
      "binding": "DOCUMENTS_BUCKET",
      "bucket_name": "questgen-test"
    }
  ],
  "workflows": [
    {
      "binding": "GENERATION_WORKFLOW",
      "name": "questgen-generation-test",
      "class_name": "GenerationWorkflow"
    }
  ]
}
